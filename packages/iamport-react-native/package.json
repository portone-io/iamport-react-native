{
  "name": "iamport-react-native",
  "version": "3.0.3",
  "description": "리액트 네이티브용 아임포트 결제/본인인증 연동 라이브러리",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/portone-io/iamport-react-native.git"
  },
  "author": "Hyukgyu Kwon <me@kwon.hk>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/portone-io/iamport-react-native/issues"
  },
  "homepage": "https://github.com/portone-io/iamport-react-native#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@react-native/babel-preset": "0.83.6",
    "@react-native/eslint-config": "0.83.6",
    "@types/jest": "^30.0.0",
    "@types/react": "catalog:",
    "del-cli": "^7.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "react": "catalog:",
    "react-native": "catalog:",
    "react-native-builder-bob": "^0.41.0",
    "react-native-webview": "^13.16.1",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-webview": "*"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "languages": "js",
    "type": "library",
    "version": "0.54.8"
  },
  "dependencies": {
    "query-string": "^9.3.1"
  }
}
